# ── Banco de Dados ──────────────────────────────────────────
DB_HOST=localhost
DB_USER=aics_user
DB_PASS=your_secure_password
DB_NAME=aics_db

# ── JWT — gere com: openssl rand -base64 48 ─────────────────
JWT_SECRET=change_me_min_32_chars_openssl_rand_base64_48

# ── App ─────────────────────────────────────────────────────
PORT=3000
APP_URL=https://yourdomain.com
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com

# ── Email (Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
SMTP_FROM=noreply@yourdomain.com

# ── IA — Anthropic Claude (Sprint 2) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Storage S3/R2 ────────────────────────────────────────────
S3_BUCKET=aics-uploads
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_KEY=your_access_key
S3_SECRET=your_secret_key

# ── Registro público (false = apenas convites) ───────────────
REGISTRATION_OPEN=true

# ── Log level ────────────────────────────────────────────────
LOG_LEVEL=info

# ── S3/R2 — URL pública dos arquivos (Sprint 3) ──────────────────────────────
# Para Cloudflare R2 com domínio personalizado:
# S3_PUBLIC_URL=https://cdn.yourdomain.com
# Para AWS S3 (sem ACL pública, use presigned URLs ou CloudFront):
# S3_PUBLIC_URL=https://d123abc.cloudfront.net


# ── IA — Replicate (Sprint 5: Geração de Imagens) ────────────────────────────
# Crie uma conta em https://replicate.com e copie o token em Account → API tokens
# Tokens começam com r8_
REPLICATE_API_TOKEN=r8_your_token_here

# ── Meta (Instagram + Facebook) ─────────────────────────────────────────────
# Crie um App em https://developers.facebook.com → Meu App → Configurações Básicas
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Permissões necessárias no App: pages_show_list, pages_manage_posts,
# instagram_basic, instagram_content_publish, pages_read_engagement

# ── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Crie em https://developers.facebook.com → Meu App → WhatsApp → Configuração
WHATSAPP_TOKEN=your_whatsapp_permanent_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_whatsapp_business_account_id
# Token para verificação de webhook (escolha qualquer string secreta)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=aics-webhook-token

# Limite de upload (em MB) — padrão 20MB
# UPLOAD_MAX_MB=50

# ── Scheduler (Sprint 3) ─────────────────────────────────────────────────────
# O scheduler roda automaticamente. Para desabilitar (ex: workers separados):
# SCHEDULER_ENABLED=false

# ── LinkedIn API ─────────────────────────────────────────────────────────────
# App em https://developer.linkedin.com → Create App
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ── AssemblyAI (Transcrição de vídeo) ────────────────────────────────────────
# Obtenha em https://www.assemblyai.com
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# ── Pagamentos (escolha um) ───────────────────────────────────────────────────
# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# OU Asaas (Brasil)
ASAAS_API_KEY=your_asaas_api_key
ASAAS_ENVIRONMENT=production

# ── TikTok Content Posting API ───────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ── Google OAuth (YouTube + GA4 + Google Ads + Business Profile) ─────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_dev_token

# ── Pinterest ────────────────────────────────────────────────────────────────
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret

# ── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# ── ElevenLabs (Voz sintética) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ── HeyGen (Avatar de vídeo) ─────────────────────────────────────────────────
HEYGEN_API_KEY=your_heygen_api_key

# ── White-label ──────────────────────────────────────────────────────────────
WHITELABEL_CNAME_TARGET=app.xpoent.com

# ── Backup automático ────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups

# ── Push notifications (VAPID) ───────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@xpoent.com
